    "type": "git",
    "url": "https://github.com/yourcompany/petrogo-admin.git"
  },
  "bugs": {
    "url": "https://github.com/yourcompany/petrogo-admin/issues"
  },
  "homepage": "https://github.com/yourcompany/petrogo-admin#readme"
